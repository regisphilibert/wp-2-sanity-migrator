{
  "name": "sanity-migrator",
  "type": "module",
  "private": true,
  "version": "1.0.0",
  "main": "export.js",
  "license": "UNLICENSED",
  "imports": {
    "#config": "./config.js",
    "#utils/*": "./utils/*",
    "#transformers/*": "./transformers/*",
    "#pt/*": "./pt/*"
  },
  "scripts": {
    "gen": "node export.js && cat ./sanity_export.json | json2nd > ./sanity_export.ndjson",
    "view": "node scripts/viewReadable.js",
    "export:output": "node scripts/output.js",
    "export:test": "node scripts/test.js",
    "export": "sanity dataset import ./sanity_export.ndjson staging --allow-failing-assets --replace",
    "dataset:delete": "sanity dataset delete production"
  },
  "keywords": [
    "sanity"
  ],
  "dependencies": {
    "log-update": "^8.0.0",
    "picocolors": "^1.1.1",
    "react-is": "^18.2.0",
    "sanity": "^3.30.1"
  },
  "prettier": {
    "semi": false,
    "printWidth": 100,
    "bracketSpacing": false,
    "singleQuote": true
  }
}
